Try this. It uses RcppArmadillo which has a resize() member function.


// [[Rcpp::depends(RcppArmadillo)]]

#include <RcppArmadillo.h>


// [[Rcpp::export]]
arma::colvec f1(std::string typ){
  arma::colvec xx;
  if (typ=="nc"){
    xx.resize(10);
  } else {
    xx.resize(20);
  }
  return xx;
}

