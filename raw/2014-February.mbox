HLM

#include <Rcpp.h>
using namespace Rcpp;

// [[Rcpp::export]]
Rcpp::NumericMatrix f1(String h){
  String h1 = h;

  NumericMatrix out1(5,5);
  NumericMatrix out2(3,3);
  NumericMatrix out3(5,4);
  std::fill(out2.begin(), out2.end(), 8);
