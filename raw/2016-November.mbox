Hi, Jingyu,

I post a small example below. I think this is what you want.

Best,

KK

#include <Rcpp.h>

using namespace Rcpp;

//[[Rcpp::export]]
void test(Nullable<Function> f = R_NilValue) {
  if (f.isNotNull()) {
    Rcpp::Rcout << "Not NULL fun" << std::endl;
    Function f2(f);
    f2();
  } else {
    Rcout << "NULL fun" << std::endl;
  }
}

/* R code
> Rcpp::sourceCpp("test.cpp")
> f_test <- function() {
+ print("test fun")
+ }
> test(f_test)
Not NULL fun
[1] "test fun"
> test()
NULL fun
*/




