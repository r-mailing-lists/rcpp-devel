> | > ## create a new environment associated with the function
> | > funenv <- environment(fun=Rastrigin)
> | > assign("mul", 2, envir=funenv)        ## set value
> | >
> | > out <- DEoptim(Rastrigin, -25, 25,
> | >                 control=list(NP=10, trace=0),
> | >                 env=funenv)
