class vector_Of_father {

   public:
     std::vector<father*> MyfatherList_;
     ~vector_Of_father(){};
     vector_Of_father() : MyfatherList_(){};
	
     father* vec_get( int i) { return MyfatherList_.at(i); };

	void WhoAmI(int i) const {
		MyfatherList_[i]->WhoAmI();
