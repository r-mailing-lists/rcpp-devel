     };
};

class children1_t : public father
{

   public:
     ~children1_t(){};
     children1_t(){};
     children1_t(children1_t const & x){};
     virtual void WhoAmI() const{
       Rcout<<"son1"<<endl;
     };
};

class children2_t : public father
{
