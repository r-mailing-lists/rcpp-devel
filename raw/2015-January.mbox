Gianluca Bonitta


library(inline)

inc <- ' NumericVector foo(const Rcpp::NumericVector &amp;x) { 
        return - pow(x,2);
                        } '
code<- '
   Rcpp:: NumericVector start(Sexp_start);
   Rcpp:: Environment stats("package:stats"); 
   Rcpp:: Function optim = stats["optim"];    
   Rcpp:: List Opt;

   Opt=optim(_["par"]     = start,
             _["fn"]      = Rcpp::InternalFunction(&amp;foo),
             _["method"]  = "BFGS");
return Opt;
'
fun.cpp <- cxxfunction(signature( Sexp_start = "NumericVector"),
                                           code, 
                                           include    = inc,
                                           plugin     = "Rcpp" )
fun.cpp (Sexp_start=0.1)

#### R code ####
fun. <- function(x) x^2
optim(0.1,fun.,method  = "BFGS")  
