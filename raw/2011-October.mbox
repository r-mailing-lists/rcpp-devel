           zty += trans(zwedge(i,0))*ytilwedge(i,0);
        }
        phi = taue*ztz + Pmat; phiinv = inv( symmatl(phi) );
        h = taue*phiinv*zty;
        U = chol(phiinv);
        colvec noisevec = randn<colvec>(p);
        b = trans(U)*noisevec + h;
        END_RCPP
    }

