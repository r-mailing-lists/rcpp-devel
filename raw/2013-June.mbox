PS Once-more modified 'tony.cpp' below

#include <Rcpp.h>

// [[Rcpp::export]]
Rcpp::DataFrame truncateTest() {

  Rcpp::NumericVector l;
  std::vector<int> v;

  for (int i=1; i<=10; i++) {
    v.push_back(i);
    l.push_back(i);
  }

  v.erase(v.begin()+5,v.end());
  l.erase(l.begin()+5,l.end());

  return(Rcpp::DataFrame::create(Rcpp::Named("STL")=v, 
				 Rcpp::Named("Rcpp")=l));
}

/*** R
truncateTest()
*/


