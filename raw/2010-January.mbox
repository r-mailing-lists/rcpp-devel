+	test.ExpressionVector.variadic <- function(){
+		funx <- cfunction(signature(), '
+		ExpressionVector x(2) ;
+		x[0] = Symbol( "rnorm" ) ;
+		x[1] = Language( "rnorm", 10.0 ) ;
+		return x ;', 
