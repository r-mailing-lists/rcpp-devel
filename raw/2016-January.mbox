And I now have a MRE:

#include <Rcpp.h>
using namespace Rcpp;

// [[Rcpp::export]]
IntegerVector ouch(IntegerVector x, IntegerVector y) {
  IntegerVector result;
  result = x[y - 1];
  return result;
}

/*** R
x <- 1:1E6
y <- 1:1E6
gctorture(TRUE)
x <- ouch(x, y)
gctorture(FALSE)
*/

This fails pretty reliably for me. Perhaps we can add this to our unit tests.

