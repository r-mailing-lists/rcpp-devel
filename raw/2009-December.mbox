+
+uncaught_cpp_exception <- function( message = "uncaught C++ exception" ){
+	callstack <- sys.calls()
+	ncalls <- length(callstack)
+	call <- if( ncalls > 1L) callstack[[ ncalls - 1L ]] else match.call()
+	classes <- c( "C++Error", "error", "condition" )
+	condition <- structure( 
+		list( message = message, call = call ), 
+		class = classes )
+	stop( condition )
+}
+

