SEXP newRcppMatrixExample(SEXP _parms) {
    Rcpp::List test(_parms);
    try{ 
        Rcpp::NumericMatrix orig(_parms);	// creates Rcpp matrix from SEXP
        Rcpp::NumericMatrix mat(orig.nrow(), orig.ncol());	

