R --vanilla CMD INSTALL inheritence

brother <- setRefClass("brother",
    contains=World,
    methods = list(
          deal = function() {
                message("George Orwell")
          },

          set = function( msg ) {

                message( "1984" )
                callSuper( msg )
          }
    ))

big <- brother$new()

# works as adverised
brave <- new ( World )
brave$set(  'Aldous Huxley' )

big$deal() # reachable
