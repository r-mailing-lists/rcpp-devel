+.badOSX <- (Sys.info()['sysname'] == "Darwin" &&
+            isTRUE(as.integer(gsub("\\..*","",Sys.info()['release'])) < 10L) )
 
+if( Rcpp:::capabilities()[["Rcpp modules"]] && ! .badOSX ) {
