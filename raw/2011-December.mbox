        x = -8.773321
        x = -8.773321
        [1] 0 0 0 5
        > rnorm(2)
        [1]  0.9520938 -2.0510458
        > rwRcpp(2,5)
        x = -0.438619
        x = 0.606704
        x = -0.658996
        x = -0.082486
        x = -2.124667
        x = -0.127444
        x = 0.447259
        x = -0.363092
