You just need an explicit type conversion like so:

funk2 <- cxxfunction(body='RNGScope scope;
           NumericVector rn(5);
           for (int i=0; i < 5; i++) rn[i] = as<double>(rnorm(1,0,1));
           return wrap(rn);',
           includes="using namespace Rcpp;\n", plugin="Rcpp")

funk2()


