arma::mat pointer method worked; while I trying to get the same result with
arma::mat view without copying data, or passing the entire matrix seemed to
be laborious.
The following patter provides read/write access to some memory location
using armadillo matrix operations.


/*
 * Contact: Steven Varga
 *          steven.varga at gmail.com
 *          2013 Toronto, On Canada
 */

#include <R.h>
#include <stdlib.h>
#include <RcppArmadillo.h>
using namespace std;

// [[Rcpp::depends(RcppArmadillo)]]
struct Example {

    Example(double *ptr) {

        A= new arma::mat(ptr, 3,2, false, true ); // no copy contstructor
                arma::mat &a = *A; // dereferencing A gets rid of A-> syntax
                a(1,1) = 1; // convenient matlab like syntax
    }

        ~Example(){ delete A; } // clean up
    arma::mat *A;
};

// [[Rcpp::depends(RcppArmadillo)]]
// [[Rcpp::export]]
void  arma_example() {

    arma::mat M(3,10); // implicit memory allocation

    M.zeros(); // paint with zeros
    M.print(); cout<<endl<<endl;

    Example E(M.memptr());
    M.print(); // altered as planned
}
// EOF


