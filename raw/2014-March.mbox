>  int ncol  = Am.ncol();
> 
>      for (int ii = 1; ii < nrows; ii++) {
>         for (int jj = 1; jj<ncol; jj++)  {
>         Am[ii,jj] =  a[jj] * exp(jj/(T-1)*log( b[jj] / a[jj] ));
>         }}
> return Am;
