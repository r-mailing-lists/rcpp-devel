> |     double rU;
> |     int ii, jj;
> |     int size_1 = size - 1;
> |     arma::uvec perm = arma::sort_index(prob, 1); //descending sort of index
> |     prob = arma::sort(prob, 1);  // descending sort of prob
> |     // cumulative probabilities 
> |     prob = arma::cumsum(prob);
> |     // compute the sample 
> |     for (ii = 0; ii < size; ii++) {
> |         rU = unif_rand();
> |         for (jj = 0; jj < size_1; jj++) {
