>>        return method<REALSXP>(x);    \
>>      case INTSXP:                    \
>>        return method<INTSXP>(x);     \
>>      case STRSXP:                    \
>>        return method<STRSXP>(x);     \
>>      case LGLSXP:                    \
>>        return method<LGLSXP>(x);     \
>>      default:                        \
