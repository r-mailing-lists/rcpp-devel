class Distance {
public:
     typedef double result_type ;
     Distance( double x_ ) : x(x_){}

     inline double operator()(double y) const { return pow( (y-x), 2.0 ) ; }

private:
     double x;
} ;

// [[Rcpp::export]]
NumericVector pdist5(double x, NumericVector ys) {
   return sapply( ys, Distance(x) ) ;
}


