> |     int size_1 = size - 1;
> |     double rT, mass, totalmass = 1.0;
> |     arma::uvec perm = arma::sort_index(prob, 1); //descending sort of index
> |     prob = arma::sort(prob, 1);  // descending sort of prob
> |     // compute the sample 
> |     for (ii = 0; ii < size; ii++, size_1--) {
