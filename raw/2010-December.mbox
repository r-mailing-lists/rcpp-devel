    ,  _simulated(false)
    ,  _E(E_)
    , _sigma(sigma_)
    , _r(r_)
  {}  

private:
  bool             _initialized;
  bool             _simulated;
  asset_type  _E;
  parm_type  _sigma;
  parm_type  _r;
};

}

#endif










