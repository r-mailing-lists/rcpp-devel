>> R numeric array by Rcpp::wrap?
>> 
>> For example, I wish to have:
>> 
>> 
>> template <class size_type, class element_type>
>> Rcpp::NumericVector
>> convert
>> (element_type*obj
>> ,size_type*n
>> )
>> {
>> Rcpp::NumericVectorRvec;
>> Rvec.reserve(n);
>> std::copy( *obj , *(obj+n), std::back_inserter(Rvec));
