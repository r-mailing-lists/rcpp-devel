Or (from svn rev 4144), you can use the collapse funtion:

// [[Rcpp::export]]
CharacterVector pasteColumns2(CharacterMatrix m){
     int nr = m.nrow() ;
     CharacterVector out(nr) ;
     for( int i=0; i<nr; i++)
         out[i] = collapse( m(i,_) ) ;
     return out ;
}

Romain

