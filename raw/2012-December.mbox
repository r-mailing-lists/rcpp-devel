|         #if __has_feature(cxx_variadic_templates)
|             #define HAS_VARIADIC_TEMPLATES
|         #endif
| 
|         #if __has_feature(cxx_static_assert)
|             #define HAS_STATIC_ASSERT
|         #endif
|     #endif // __cplusplus >= 201103L
| #elif defined(__GNUC__)
