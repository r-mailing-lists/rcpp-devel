RcppExport SEXP myfunc(SEXP _n, SEXP _x) {
   const int n=Rcpp::as<int>(_n);

   double *x=(double *)malloc(n*sizeof(double));

   Eigen::Map<Eigen::VectorXd> map_x(x, n);

   map_x=Rcpp::as< Eigen::Map<Eigen::VectorXd> >(_x);

   double a=fit(x, n);

...

