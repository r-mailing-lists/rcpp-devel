Perhaps use the clone() function?

library(Rcpp)

cppFunction("
NumericVector par_CMAtR(NumericVector vec_CMA) {
    NumericVector out = clone(vec_CMA);
    out[5] = exp(out[5]);
    return out;
}
")

vec_C <- rep(1, 6)
par_CMAtR(vec_C)
print(vec_C)

