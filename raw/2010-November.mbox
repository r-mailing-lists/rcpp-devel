#+BEGIN_SRC R
  dispRparForSugar <- function(
                               maxx  = maxx,
                               maxy  = maxy,
                               seeds = seeds,
                               sd2D  = sd2D,
                               dx    = dx,
                               dy    = dy,
                               dispSeeds = dispSeeds # the return value
                               ) {
    library(inline)
    library(Rcpp)
    dx2 <- 2*dx
    dy2 <- 2*dy


    fx2 <- cxxfunction(
