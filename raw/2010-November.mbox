PROB = "double"),
                       body = '
                                   Rcpp::IntegerVector n (N);
                                   Rcpp::IntegerVector size (SIZE);
                                   Rcpp::NumericVector prob (PROB);

                                   int res;
                                   res = 0;

                                   for( int i=0; i<n.size(); i++){
                                        if (size[i]>0) {
                                          res += rbinom( 1, size[i],
prob[i] )[0];
