double   e,x1,x2,err,yr,r;
int      maxiter,k;

x1=0.0;
x2=1.0;
e =1e-10;
maxiter = 10;



a[1] = BrentRoots(x1,x2,e,maxiter,&yr,&k,&err);
a[2] = BrentRoots(x1,x2,e,maxiter,&yr,&k,&err);

