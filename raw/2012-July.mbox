  unsigned int b = 100;
  Rcpp::List lst(a);
  size_t a = Rcpp::as<unsigned int>(lst["a"]);
  lst["b"] = b;
  size_t c = 1000;
  long long ll = 100;
  #ifdef RCPP_HAS_LONG_LONG_TYPES
    Rcpp::Rcout << "in ifdef" << std::endl;
  #endif
  Rcpp::NumericVector nv(c);
