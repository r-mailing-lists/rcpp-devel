Message-ID: <4BFD3350.8000103@r-enthusiasts.com>

Here is a self contained example, that uses both svn version of Rcpp and 
svn version of inline (for getDynLib) :


require( Rcpp )
require( methods )

code <- ''

inc  <- '

class World {
public:
     World() : msg("hello"){}
     void set(std::string msg) { this->msg = msg; }
     std::string greet() { return msg; }

private:
     std::string msg;
};



RCPP_MODULE(yada){
	using namespace Rcpp ;
	class_<World>( "World" )
		.method( "greet", &World::greet )
		.method( "set", &World::set )
	;
}

'
fx <- cppfunction( signature(), "", include = inc )

yada <- Rcpp:::Module( "yada", getDynLib( fx ) )
World <- yada$World

w <- new( World )
print( w$greet() )
w$set( "hello world" )
w$greet()

Romain


