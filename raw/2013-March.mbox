public:
    int cells;
};

class cluslist {
public:
    std::vector list;
};

#include 

RCPP_EXPOSED_CLASS(cluster)
RCPP_EXPOSED_CLASS_NODECL(std::vector) // XXX KEY LINE!!!
RCPP_EXPOSED_CLASS(cluslist)

using namespace Rcpp;
RCPP_MODULE(cluster_module) {
    class_("cluster")
        .constructor()
