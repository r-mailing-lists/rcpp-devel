Using code from the first unit test example I found on List, and making it
two level:


#include <Rcpp.h>

using namespace Rcpp;

// [[Rcpp::export]]
List reclist(){
    List a(2);
    List output(2);
    output[0] = IntegerVector::create( 10, 20 ) ;
    output[1] = IntegerVector::create(_["foo"] = 20,
				      _["bar"] = 30 ) ;
    a[0] = output;
    a[1] = output;
    return a;
}


