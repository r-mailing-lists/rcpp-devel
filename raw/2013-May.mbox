  R> 

and the file soren.cpp is below.

Dirk


#include <Rcpp.h>

using namespace Rcpp;

// [[Rcpp::export]]
NumericMatrix soren(NumericVector x, int n, int k) {
  return NumericMatrix(n, k, x.begin()); }

